{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "gentoo_mirrors",
  "rules": {
    "file": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "comment"
          },
          {
            "type": "SYMBOL",
            "name": "blank_line"
          },
          {
            "type": "SYMBOL",
            "name": "entry"
          }
        ]
      }
    },
    "blank_line": {
      "type": "PATTERN",
      "value": "[ \\t]*\\n"
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "#"
          },
          {
            "type": "PATTERN",
            "value": "[^\\n]*"
          }
        ]
      }
    },
    "entry": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "PATTERN",
              "value": "[ \\t]+"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "category"
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "PATTERN",
                "value": "[ \\t]+"
              },
              {
                "type": "SYMBOL",
                "name": "url"
              }
            ]
          }
        },
        {
          "type": "PATTERN",
          "value": "[ \\t]*"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": "\n"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "category": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 2,
        "content": {
          "type": "PATTERN",
          "value": "[A-Za-z0-9_.+-]+"
        }
      }
    },
    "url": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "http_url"
        },
        {
          "type": "SYMBOL",
          "name": "https_url"
        },
        {
          "type": "SYMBOL",
          "name": "ftp_url"
        },
        {
          "type": "SYMBOL",
          "name": "generic_url"
        }
      ]
    },
    "http_url": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 3,
        "content": {
          "type": "PATTERN",
          "value": "http:\\/\\/[^ \\t\\n]+"
        }
      }
    },
    "https_url": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 3,
        "content": {
          "type": "PATTERN",
          "value": "https:\\/\\/[^ \\t\\n]+"
        }
      }
    },
    "ftp_url": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 3,
        "content": {
          "type": "PATTERN",
          "value": "ftp:\\/\\/[^ \\t\\n]+"
        }
      }
    },
    "generic_url": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 1,
        "content": {
          "type": "PATTERN",
          "value": "[a-z][a-z0-9+.-]*:\\/\\/[^ \\t\\n]+",
          "flags": "i"
        }
      }
    }
  },
  "extras": [],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}