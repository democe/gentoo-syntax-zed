{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "gentoo_package_properties",
  "rules": {
    "file": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "comment"
          },
          {
            "type": "SYMBOL",
            "name": "blank_line"
          },
          {
            "type": "SYMBOL",
            "name": "entry"
          }
        ]
      }
    },
    "blank_line": {
      "type": "PATTERN",
      "value": "[ \\t]*\\n"
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "#"
          },
          {
            "type": "PATTERN",
            "value": "[^\\n]*"
          }
        ]
      }
    },
    "entry": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "PATTERN",
              "value": "[ \\t]+"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "atom"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "PATTERN",
                "value": "[ \\t]+"
              },
              {
                "type": "SYMBOL",
                "name": "property"
              }
            ]
          }
        },
        {
          "type": "PATTERN",
          "value": "[ \\t]*"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": "\n"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "atom": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 2,
        "content": {
          "type": "PATTERN",
          "value": "[^\\s#\\/]+\\/[^\\s#]+"
        }
      }
    },
    "property": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "property_neg"
        },
        {
          "type": "SYMBOL",
          "name": "property_wild"
        },
        {
          "type": "SYMBOL",
          "name": "property_name"
        }
      ]
    },
    "property_neg": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 2,
        "content": {
          "type": "PATTERN",
          "value": "-[A-Za-z0-9_-]+"
        }
      }
    },
    "property_wild": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 3,
        "content": {
          "type": "PATTERN",
          "value": "\\*|\\-\\*"
        }
      }
    },
    "property_name": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 1,
        "content": {
          "type": "PATTERN",
          "value": "[A-Za-z0-9_-]+"
        }
      }
    }
  },
  "extras": [],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}