{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "gentoo-package-license",
      "camelcase": "GentooPackageLicense",
      "title": "Gentoo Package License",
      "scope": "source.gentoo-package-license",
      "injection-regex": "^gentoo-package-license$",
      "class-name": "TreeSitterGentooPackageLicense"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "tree-sitter grammar for Gentoo Gentoo Package License files",
    "authors": [{ "name": "democe <democe@democe.com>" }],
    "links": { "repository": "https://github.com/democe/gentoo-syntax-zed" }
  },
  "bindings": { "c": true, "go": false, "node": false, "python": false, "rust": false, "swift": false }
}
