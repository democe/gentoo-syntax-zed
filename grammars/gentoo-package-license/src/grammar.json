{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "gentoo_package_license",
  "rules": {
    "file": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "comment"
          },
          {
            "type": "SYMBOL",
            "name": "blank_line"
          },
          {
            "type": "SYMBOL",
            "name": "entry"
          }
        ]
      }
    },
    "blank_line": {
      "type": "STRING",
      "value": "\n"
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "#"
          },
          {
            "type": "PATTERN",
            "value": "[^\\n]*"
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "STRING",
                "value": "\n"
              },
              {
                "type": "BLANK"
              }
            ]
          }
        ]
      }
    },
    "entry": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "atom"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "license_spec"
          }
        }
      ]
    },
    "atom": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 2,
        "content": {
          "type": "PATTERN",
          "value": "[^\\n \\t#\\/]+\\/[^\\n \\t#]+"
        }
      }
    },
    "license_spec": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "license_expand"
        },
        {
          "type": "SYMBOL",
          "name": "license_group"
        },
        {
          "type": "SYMBOL",
          "name": "license_neg"
        },
        {
          "type": "SYMBOL",
          "name": "license"
        },
        {
          "type": "SYMBOL",
          "name": "star"
        }
      ]
    },
    "license_expand": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 3,
        "content": {
          "type": "PATTERN",
          "value": "[A-Za-z0-9][A-Za-z0-9_-]*:"
        }
      }
    },
    "license_group": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 3,
        "content": {
          "type": "PATTERN",
          "value": "-?@[A-Za-z0-9_.+-]+"
        }
      }
    },
    "license_neg": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 2,
        "content": {
          "type": "PATTERN",
          "value": "-([A-Za-z0-9_.+-]+|\\*)"
        }
      }
    },
    "star": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 3,
        "content": {
          "type": "PATTERN",
          "value": "\\*"
        }
      }
    },
    "license": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 1,
        "content": {
          "type": "PATTERN",
          "value": "[A-Za-z0-9_.+-]+"
        }
      }
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[ \\t]+"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}